# Signing secret for grant tokens (set a real random value)
KEYRING_SIGNING_SECRET=change-me

# Proxy + server ports
KEYRING_PROXY_PORT=8080
KEYRING_SERVER_PORT=3000

# Approval timeout (ms) the proxy waits before refusing
KEYRING_APPROVAL_TIMEOUT=60000

# --- Slack (optional). If unset, KEYRING uses the local CLI/dashboard approver. ---
# Bot token (xoxb-...). Required scopes: chat:write
SLACK_BOT_TOKEN=
# Signing secret from your Slack app's Basic Information page. Used to verify
# interactivity callbacks; without it KEYRING refuses all Slack POSTs with 401.
SLACK_SIGNING_SECRET=
# Channel ID (e.g. C0123456789) or channel name (#engineering). The bot must be
# a member of this channel before chat.postMessage will work.
SLACK_APPROVAL_CHANNEL=

# Optional: shown as "Open dashboard" link in the Slack approval message.
KEYRING_DASHBOARD_URL=
